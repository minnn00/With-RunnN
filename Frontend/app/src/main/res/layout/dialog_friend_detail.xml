<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- 더보기(점 3개) -->
    <ImageView
        android:id="@+id/ivMore"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_menu"
        android:contentDescription="더보기"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="32dp" />

    <!-- 프로필 이미지 (라운드 흰색 사각형 배경) -->
    <FrameLayout
        android:id="@+id/profileImageFrame"
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="56dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ImageView
            android:id="@+id/ivProfileImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/rectangle_32913"
            android:scaleType="centerCrop"
            android:clipToOutline="true"
            android:src="@drawable/img_profile_johnny" />
    </FrameLayout>

    <!-- 이름 + 성별 -->
    <LinearLayout
        android:id="@+id/nameGenderLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/profileImageFrame"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp">
        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="조니"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:fontFamily="@font/pretendard_semibold"
            android:paddingEnd="0dp"/>
        <ImageView
            android:id="@+id/ivGender"
            android:layout_width="20dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="0dp"
            android:src="@drawable/ic_male"
            android:tint="@color/green_700"
            android:contentDescription="성별"/>
    </LinearLayout>

    <!-- 소개 -->
    <TextView
        android:id="@+id/tvIntro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/nameGenderLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:text="안녕하세요! 달리기 좋아하는 3살 조니예요 :)"
        android:textSize="16sp"
        android:textColor="@color/gray_700"
        android:fontFamily="@font/pretendard_regular"
        android:gravity="center"/>

    <!-- 버튼 영역 -->
    <LinearLayout
        android:id="@+id/buttonLayout"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tvIntro"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp">
        <Button
            android:id="@+id/btnFollow"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="팔로우"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/pretendard_semibold"
            android:layout_marginEnd="8dp"
            android:background="@drawable/rounded_rectangle_green"
            android:backgroundTint="@null"
            android:stateListAnimator="@null"
            android:gravity="center"/>
        <Button
            android:id="@+id/btnMessage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="메시지"
            android:textColor="@color/green_700"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/pretendard_semibold"
            android:layout_marginStart="8dp"
            android:background="@drawable/rounded_rectangle_white_border"
            android:backgroundTint="@null"
            android:stateListAnimator="@null"
            android:gravity="center"/>
    </LinearLayout>

    <!-- 정보 표 (3행 2열, 중앙 정렬) -->
    <GridLayout
        android:id="@+id/infoTable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/buttonLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:columnCount="2"
        android:rowCount="3">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="나이"
            android:textColor="@color/gray_500"
            android:textSize="16sp"
            android:fontFamily="@font/pretendard_medium"
            android:layout_row="0"
            android:layout_column="0"
            android:layout_marginVertical="8dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3년 6개월"
            android:textColor="@color/gray_700"
            android:textSize="16sp"
            android:fontFamily="@font/pretendard_medium"
            android:gravity="end"
            android:layout_gravity="end"
            android:layout_row="0"
            android:layout_column="1"
            android:layout_marginVertical="8dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="견종"
            android:textColor="@color/gray_500"
            android:textSize="16sp"
            android:fontFamily="@font/pretendard_medium"
            android:layout_row="1"
            android:layout_column="0"
            android:layout_marginVertical="8dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="래브라도 리트리버"
            android:textColor="@color/gray_700"
            android:textSize="16sp"
            android:fontFamily="@font/pretendard_medium"
            android:gravity="end"
            android:layout_gravity="end"
            android:layout_row="1"
            android:layout_column="1"
            android:layout_marginVertical="8dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="분류"
            android:textColor="@color/gray_500"
            android:textSize="16sp"
            android:fontFamily="@font/pretendard_medium"
            android:layout_row="2"
            android:layout_column="0"
            android:layout_marginVertical="8dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="대형견"
            android:textColor="@color/gray_700"
            android:textSize="16sp"
            android:fontFamily="@font/pretendard_medium"
            android:gravity="end"
            android:layout_gravity="end"
            android:layout_row="2"
            android:layout_column="1"
            android:layout_marginVertical="8dp"/>
    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout> 
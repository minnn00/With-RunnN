<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.location.LocationActivity">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/white"
            app:title="지역 변경"
            app:titleTextColor="@color/gray_900"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/gray_700" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Location Selection Container -->
    <LinearLayout
        android:id="@+id/llLocationSelection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:padding="@dimen/margin_medium"
        app:layout_constraintTop_toBottomOf="@+id/appBarLayout"
        app:layout_constraintBottom_toTopOf="@+id/llSelectedLocation">

        <!-- 시/도 선택 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="@dimen/margin_small">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="시/도"
                android:textColor="@color/gray_700"
                android:textSize="14sp"
                android:fontFamily="@font/pretendard_medium"
                android:padding="@dimen/margin_small"
                android:background="@color/gray_100" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProvince"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@color/white"
                tools:listitem="@layout/item_location" />

        </LinearLayout>

        <!-- 시/군/구 선택 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginHorizontal="@dimen/margin_small">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="시/군/구"
                android:textColor="@color/gray_700"
                android:textSize="14sp"
                android:fontFamily="@font/pretendard_medium"
                android:padding="@dimen/margin_small"
                android:background="@color/gray_100" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCity"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@color/white"
                tools:listitem="@layout/item_location" />

        </LinearLayout>

        <!-- 동/읍/면 선택 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/margin_small">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="동/읍/면"
                android:textColor="@color/gray_700"
                android:textSize="14sp"
                android:fontFamily="@font/pretendard_medium"
                android:padding="@dimen/margin_small"
                android:background="@color/gray_100" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDistrict"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@color/white"
                tools:listitem="@layout/item_location" />

        </LinearLayout>

    </LinearLayout>

    <!-- 선택된 지역 정보 -->
    <LinearLayout
        android:id="@+id/llSelectedLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin_medium"
        android:background="@color/gray_50"
        app:layout_constraintBottom_toTopOf="@+id/btnSave">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="선택된 지역"
            android:textColor="@color/gray_600"
            android:textSize="14sp"
            android:fontFamily="@font/pretendard_medium"
            android:layout_marginBottom="@dimen/margin_small" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleLine="false"
            app:chipSpacing="@dimen/margin_small">

            <!-- 선택된 지역들이 동적으로 추가될 예정 -->

        </com.google.android.material.chip.ChipGroup>

    </LinearLayout>

    <!-- 저장 버튼 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="저장하기"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:fontFamily="@font/pretendard_semibold"
        android:backgroundTint="@color/green_700"
        app:cornerRadius="@dimen/button_corner_radius"
        android:layout_margin="@dimen/margin_medium"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout> 
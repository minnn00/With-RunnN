<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/margin_medium"
    android:paddingVertical="@dimen/margin_small">

    <!-- Profile Image -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivSenderProfile"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CircleImageView"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:src="@drawable/img_app_logo" />

    <!-- Sender Name -->
    <TextView
        android:id="@+id/tvSenderName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="마루"
        android:textColor="@color/gray_700"
        android:textSize="12sp"
        android:fontFamily="@font/pretendard_medium"
        android:layout_marginStart="@dimen/margin_small"
        android:layout_marginBottom="2dp"
        app:layout_constraintTop_toTopOf="@+id/ivSenderProfile"
        app:layout_constraintStart_toEndOf="@+id/ivSenderProfile"
        tools:text="마루" />

    <!-- Message Container -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvMessageContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="60dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toBottomOf="@+id/tvSenderName"
        app:layout_constraintStart_toEndOf="@+id/ivSenderProfile"
        app:layout_constraintHorizontal_bias="0.0"
        android:layout_marginStart="@dimen/margin_small">

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="네! 좋은 하루 되세요~"
            android:textColor="@color/gray_800"
            android:textSize="14sp"
            android:fontFamily="@font/pretendard_regular"
            android:padding="@dimen/margin_medium"
            android:maxWidth="250dp"
            tools:text="네! 좋은 하루 되세요~" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Message Time -->
    <TextView
        android:id="@+id/tvMessageTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="오전 11:15"
        android:textColor="@color/gray_500"
        android:textSize="12sp"
        android:fontFamily="@font/pretendard_regular"
        android:layout_marginStart="@dimen/margin_small"
        app:layout_constraintBottom_toBottomOf="@+id/cvMessageContainer"
        app:layout_constraintStart_toEndOf="@+id/cvMessageContainer"
        tools:text="오전 11:15" />

</androidx.constraintlayout.widget.ConstraintLayout> 
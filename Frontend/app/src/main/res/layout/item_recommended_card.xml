<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="@dimen/margin_medium"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="8dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 배경 그라데이션 -->
        <View
            android:id="@+id/gradientOverlay"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/gradient_overlay"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 반려견 사진 -->
        <ImageView
            android:id="@+id/ivDogImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:src="@drawable/img_app_logo" />

        <!-- 하단 정보 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_medium"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 이름과 나이 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/margin_small">

                <TextView
                    android:id="@+id/tvDogName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="마루"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:fontFamily="@font/pretendard_semibold"
                    tools:text="마루" />

                <TextView
                    android:id="@+id/tvDogAge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2년 4개월"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:fontFamily="@font/pretendard_medium"
                    tools:text="2년 4개월" />

            </LinearLayout>

            <!-- 견종과 지역 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/margin_small">

                <TextView
                    android:id="@+id/tvBreed"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="골든리트리버"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="@font/pretendard_regular"
                    tools:text="골든리트리버" />

                <TextView
                    android:id="@+id/tvLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="서울 마포구"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="@font/pretendard_regular"
                    tools:text="서울 마포구" />

            </LinearLayout>

            <!-- 매칭 태그들 -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleLine="false"
                app:chipSpacing="4dp"
                app:chipSpacingHorizontal="4dp"
                app:chipSpacingVertical="4dp">

                <!-- Sample Chips - will be populated dynamically -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSample1"
                    style="@style/Widget.Material3.Chip.Assist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="활발함"
                    android:textSize="12sp"
                    android:textColor="@color/green_700"
                    app:chipBackgroundColor="@color/white"
                    app:chipCornerRadius="@dimen/chip_corner_radius"
                    app:chipMinHeight="28dp"
                    app:chipStrokeWidth="0dp"
                    tools:visibility="visible" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSample2"
                    style="@style/Widget.Material3.Chip.Assist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="친화적"
                    android:textSize="12sp"
                    android:textColor="@color/green_700"
                    app:chipBackgroundColor="@color/white"
                    app:chipCornerRadius="@dimen/chip_corner_radius"
                    app:chipMinHeight="28dp"
                    app:chipStrokeWidth="0dp"
                    tools:visibility="visible" />

            </com.google.android.material.chip.ChipGroup>

        </LinearLayout>

        <!-- 우상단 더보기 버튼 -->
        <ImageView
            android:id="@+id/ivMore"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_menu"
            android:background="@drawable/circle_background_white"
            android:padding="6dp"
            android:layout_margin="@dimen/margin_medium"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/gray_700"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView> 
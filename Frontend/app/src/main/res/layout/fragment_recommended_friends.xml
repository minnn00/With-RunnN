<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- ViewPager2 for dog profiles -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerRecommendedFriends"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/tabLayoutIndicator" />

    <!-- Tab layout for indicators -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutIndicator"
        android:layout_width="wrap_content"
        android:layout_height="10dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="60dp"
        app:tabBackground="@drawable/tab_selector_indicator"
        app:tabGravity="center"
        android:minHeight="0dp"
        app:tabIndicatorHeight="0dp"
        app:tabPaddingStart="4dp"
        app:tabPaddingEnd="4dp" />

    <!-- Empty state layout -->
    <LinearLayout
        android:id="@+id/llEmptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_friends" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="추천 친구가 없습니다"
            android:textColor="@color/gray_700"
            android:textSize="16sp" />
    </LinearLayout>

</RelativeLayout> 